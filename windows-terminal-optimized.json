{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",

    "actions": [
        // Copy & Paste
        {"command": {"action": "copy", "singleLine": false}, "keys": "ctrl+c"},
        {"command": "paste", "keys": "ctrl+v"},

        // Tab Management
        {"command": "newTab", "keys": "ctrl+t"},
        {"command": "duplicateTab", "keys": "ctrl+shift+d"},
        {"command": "closeTab", "keys": "ctrl+w"},
        {"command": {"action": "nextTab"}, "keys": "ctrl+tab"},
        {"command": {"action": "prevTab"}, "keys": "ctrl+shift+tab"},
        {"command": {"action": "switchToTab", "index": 0}, "keys": "ctrl+1"},
        {"command": {"action": "switchToTab", "index": 1}, "keys": "ctrl+2"},
        {"command": {"action": "switchToTab", "index": 2}, "keys": "ctrl+3"},
        {"command": {"action": "switchToTab", "index": 3}, "keys": "ctrl+4"},
        {"command": {"action": "switchToTab", "index": 4}, "keys": "ctrl+5"},

        // Pane Management
        {"command": {"action": "splitPane", "split": "horizontal"}, "keys": "alt+shift+minus"},
        {"command": {"action": "splitPane", "split": "vertical"}, "keys": "alt+shift+plus"},
        {"command": {"action": "splitPane", "split": "auto", "splitMode": "duplicate"}, "keys": "alt+shift+d"},
        {"command": "closePane", "keys": "ctrl+shift+w"},

        // Pane Navigation
        {"command": {"action": "moveFocus", "direction": "down"}, "keys": "alt+down"},
        {"command": {"action": "moveFocus", "direction": "left"}, "keys": "alt+left"},
        {"command": {"action": "moveFocus", "direction": "right"}, "keys": "alt+right"},
        {"command": {"action": "moveFocus", "direction": "up"}, "keys": "alt+up"},

        // Pane Resizing
        {"command": {"action": "resizePane", "direction": "down"}, "keys": "alt+shift+down"},
        {"command": {"action": "resizePane", "direction": "left"}, "keys": "alt+shift+left"},
        {"command": {"action": "resizePane", "direction": "right"}, "keys": "alt+shift+right"},
        {"command": {"action": "resizePane", "direction": "up"}, "keys": "alt+shift+up"},

        // Search & Find
        {"command": "find", "keys": "ctrl+shift+f"},
        {"command": "commandPalette", "keys": "ctrl+shift+p"},

        // Zoom
        {"command": {"action": "adjustFontSize", "delta": 1}, "keys": "ctrl+plus"},
        {"command": {"action": "adjustFontSize", "delta": -1}, "keys": "ctrl+minus"},
        {"command": "resetFontSize", "keys": "ctrl+0"},

        // Scrolling
        {"command": "scrollUp", "keys": "ctrl+shift+up"},
        {"command": "scrollDown", "keys": "ctrl+shift+down"},
        {"command": "scrollUpPage", "keys": "ctrl+shift+pgup"},
        {"command": "scrollDownPage", "keys": "ctrl+shift+pgdn"},
        {"command": "scrollToTop", "keys": "ctrl+shift+home"},
        {"command": "scrollToBottom", "keys": "ctrl+shift+end"},

        // Settings
        {"command": "openSettings", "keys": "ctrl+comma"},
        {"command": {"action": "openSettings", "target": "defaultsFile"}, "keys": "ctrl+shift+comma"},

        // Fullscreen
        {"command": "toggleFullscreen", "keys": "f11"}
    ],

    "copyFormatting": "none",
    "copyOnSelect": false,
    "defaultProfile": "{15f25581-9568-43ee-bed7-788f5ad483d0}",  // Claude Code (Ubuntu)


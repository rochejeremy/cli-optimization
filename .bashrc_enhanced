# MODERN LS REPLACEMENTS
# ============================================================
# Use eza if available, otherwise ls with colors
if command -v eza &> /dev/null; then
    alias ls='eza --icons --group-directories-first'
    alias ll='eza -l --icons --group-directories-first --git'
    alias la='eza -la --icons --group-directories-first --git'
    alias lt='eza -T --icons --group-directories-first --level=2'
    alias tree='eza -T --icons'
else
    alias ls='ls --color=auto --group-directories-first'
    alias ll='ls -lhF'
    alias la='ls -lAhF'
    alias l='ls -CF'
fi

# ============================================================
# BETTER CAT WITH BAT
# ============================================================
if command -v bat &> /dev/null; then
    alias cat='bat --paging=never'
    alias catt='bat'  # Original bat with paging
elif command -v batcat &> /dev/null; then
    alias cat='batcat --paging=never'
    alias catt='batcat'
fi

# ============================================================
# BETTER GREP WITH RIPGREP
# ============================================================
if command -v rg &> /dev/null; then
    alias grep='rg'
    alias oldgrep='/usr/bin/grep --color=auto'
else
    alias grep='grep --color=auto'
fi

# ============================================================
# BETTER FIND WITH FD
# ============================================================
if command -v fdfind &> /dev/null; then
    alias fd='fdfind'
fi
if command -v fd &> /dev/null; then
    alias find='fd'
    alias oldfind='/usr/bin/find'
fi

# ============================================================
# FZF CONFIGURATION (Fuzzy Finder)
# ============================================================
if command -v fzf &> /dev/null; then
    # Use fd for fzf if available (faster and respects .gitignore)
    if command -v fd &> /dev/null || command -v fdfind &> /dev/null; then
        export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
        export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
        export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
    fi

    # Better colors and preview
    export FZF_DEFAULT_OPTS="
        --height 40%
        --layout=reverse
        --border
        --inline-info
        --color=fg:#d0d0d0,bg:#121212,hl:#5f87af
        --color=fg+:#d0d0d0,bg+:#262626,hl+:#5fd7ff
        --color=info:#afaf87,prompt:#d7005f,pointer:#af5fff
        --color=marker:#87ff00,spinner:#af5fff,header:#87afaf
    "

    # Use bat for file preview if available
    if command -v bat &> /dev/null || command -v batcat &> /dev/null; then
        export FZF_CTRL_T_OPTS="--preview 'bat --color=always --line-range :500 {}'"
    fi

    # Fuzzy search history (Ctrl+R)
    bind '"\C-r": "\C-x1\e^\C-x2\e[0n"'
    bind -x '"\C-x1": __fzf_history';
    bind '"\C-x2": "\e[5C\C-k\C-y\ey\C-x3\e[5D"'
    bind -x '"\C-x3": "__fzf_history_post_event__"';

    __fzf_history() {
        __fzf_history__=$(fc -lnr -2147483648 | fzf +s +m -x --tac --no-sort)
    }

    __fzf_history_post_event__() {
        READLINE_LINE=${__fzf_history__}
        READLINE_POINT=${#READLINE_LINE}
    }

    # Fuzzy cd (Alt+C)
    source /usr/share/doc/fzf/examples/key-bindings.bash 2>/dev/null
fi


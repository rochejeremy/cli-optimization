# Make directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract any archive
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xvjf "$1"    ;;
            *.tar.gz)    tar xvzf "$1"    ;;
            *.tar.xz)    tar xvJf "$1"    ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.rar)       unrar x "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xvf "$1"     ;;
            *.tbz2)      tar xvjf "$1"    ;;
            *.tgz)       tar xvzf "$1"    ;;
            *.zip)       unzip "$1"       ;;
            *.Z)         uncompress "$1"  ;;
            *.7z)        7z x "$1"        ;;
            *)           echo "Unknown archive format: $1" ;;
        esac
    else
        echo "File not found: $1"
    fi
}

# Find and kill process by name
killp() {
    ps aux | grep -v grep | grep "$1" | awk '{print $2}' | xargs kill -9
}

# Quick file/directory search
ff() {
    find . -type f -iname "*$1*"
}

fdir() {
    find . -type d -iname "*$1*"
}

# ShareX screenshot helpers
latest-screenshot() {
    local screenshot_dir="/mnt/c/Users/roche/OneDrive/Documents/ShareX/Screenshots/$(date +%Y-%m)"
    if [ -d "$screenshot_dir" ]; then
        ls -t "$screenshot_dir"/*.png 2>/dev/null | head -1
    else
        echo "Screenshot directory not found: $screenshot_dir"
        return 1
    fi
}

list-screenshots() {
    local count="${1:-10}"
    local screenshot_dir="/mnt/c/Users/roche/OneDrive/Documents/ShareX/Screenshots/$(date +%Y-%m)"
    if [ -d "$screenshot_dir" ]; then
        ls -lth "$screenshot_dir"/*.png 2>/dev/null | head -"$count"
    else
        echo "Screenshot directory not found: $screenshot_dir"
        return 1
    fi
}

open-screenshot() {
    local screenshot=$(latest-screenshot)
    if [ -n "$screenshot" ]; then
        echo "Opening: $screenshot"
        explorer.exe "$screenshot"
    fi
}

# Backup a file
backup() {
    cp "$1"{,.bak-$(date +%Y%m%d-%H%M%S)}
}


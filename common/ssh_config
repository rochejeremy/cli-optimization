# SSH Configuration Template
# Copy to ~/.ssh/config

# Global defaults
Host *
    # Connection multiplexing
    ControlMaster auto
    ControlPath ~/.ssh/control-%r@%h:%p
    ControlPersist 10m

    # Keep connections alive
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Connection timeout
    ConnectTimeout 10

    # Use SSH keys
    IdentitiesOnly yes

    # Compression
    Compression yes

    # Reuse connections
    TCPKeepAlive yes

# Example: Gammadrum
Host gammadrum
    HostName <REPLACE_WITH_IP_OR_HOSTNAME>
    User <REPLACE_WITH_USERNAME>
    IdentityFile ~/.ssh/id_rsa
    # Port 22  # Uncomment if non-standard port

# Example: Remote Server
Host myserver
    HostName <REPLACE_WITH_YOUR_IP>
    User <REPLACE_WITH_USERNAME>
    IdentityFile ~/.ssh/id_rsa
    # Port 22  # Uncomment if non-standard port
    # StrictHostKeyChecking ask  # Prompts on first connect (default)

# GitHub
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_rsa

# Add more hosts as needed...
